# 🏛 5. ЕДИНАЯ СИСТЕМА УПРАВЛЕНИЯ (COLONY OS)
# ============================================================

class ColonyOS:
    def __init__(self, name: str):
        self.name = name
        self.bbox = BlackBox()
        self.state = SystemState()
        self.constitution = Constitution(self.bbox)
        
        # Модули
        self.energy = EnergyGrid()
        self.ecology = EcologySystem()
        self.space = SpaceControl(self.bbox)
        self.robots = AndroidFleet()

    def human_auth_interface(self, task: str) -> bool:
        print(f"\n👤 [ЗАПРОС АВТОРИЗАЦИИ]: {task} -> [ОДОБРЕНО]")
        return True

    def run_cycle(self, day: int):
        print(f"\n--- 🛰 {self.name} | ОТЧЕТ: ДЕНЬ {day} ---")
        
        # 1. Энергетика
        self.energy.step()
        if self.energy.npp_stability < 96.0:
            if self.human_auth_interface("Ремонт реактора АЭС"):
                self.energy.npp_stability = 100.0
                self.bbox.record("HUMAN", "REPAIR", "АЭС стабилизирована")

        # 2. Экология и Наноботы
        self.ecology.auto_cycle(self.state)
        if self.ecology.pollution > 12.0:
            if self.human_auth_interface("Выпуск нанороботов-очистителей"):
                self.ecology.deploy_nanobots(3000)
                self.bbox.record("HUMAN", "NANO_DEPLOY", "Запущено 3000 нано-единиц")

        # 3. Космос
        if random.random() > 0.6:
            ship = f"Explorer-{random.randint(100,999)}"
            auth = self.human_auth_interface(f"Запуск {ship}")
            print(self.space.request_launch(ship, 24000, auth))

        # Статус-панель
        print(f"📊 СТАТУС: Вода: {self.ecology.water_purity:.1f}% | "
              f"Токсичность нано: {self.state.nano_toxicity:.1f}/50.0 | "
              f"Реактор: {self.energy.npp_stability:.1f}%")

        # 4. Проверка Конституции
        if not self.constitution.validate(self.state):
            print("🚨 БЛОКИРОВКА СИСТЕМЫ: НАРУШЕНЫ ПРАВА КОЛОНИСТОВ!")
            return False
        return True

    def audit(self):
        print("\n" + "="*60)
        print(f"🔎 АУДИТ БЕЗОПАСНОСТИ {self.name}")
        if self.bbox.verify_integrity():
            print("✅ ЦЕЛОСТНОСТЬ ДАННЫХ ПОДТВЕРЖДЕНА. ВМЕШАТЕЛЬСТВ НЕ ОБНАРУЖЕНО.")
        else:
            print("🚨 ВНИМАНИЕ! ОБНАРУЖЕН ВЗЛОМ ИСТОРИИ СОБЫТИЙ!")
        print("="*60)

