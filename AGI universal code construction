# 📦 0. КРИПТОГРАФИЧЕСКИЙ "ЧЕРНЫЙ ЯЩИК" (IMMUTABLE LEDGER)
# ============================================================

class BlackBox:
    """Неизменяемый журнал всех событий колонии. Защищен хешированием SHA-256."""
    def __init__(self):
        self.chain: List[Dict] = []
        self.last_hash = "0" * 64

    def record(self, initiator: str, action: str, details: str):
        timestamp = time.strftime('%Y-%m-%d %H:%M:%S')
        data = f"{timestamp}|{initiator}|{action}|{details}|{self.last_hash}"
        entry_hash = hashlib.sha256(data.encode()).hexdigest()
        
        record = {
            "time": timestamp,
            "from": initiator,
            "do": action,
            "info": details,
            "prev": self.last_hash,
            "hash": entry_hash
        }
        self.chain.append(record)
        self.last_hash = entry_hash
        print(f"📦 [LOG]: {action:15} | Кто: {initiator:10} | Hash: {entry_hash[:10]}...")

    def verify_integrity(self) -> bool:
        """Проверка: не пытался ли ИИ или вирус изменить историю действий."""
        prev = "0" * 64
        for r in self.chain:
            data = f"{r['time']}|{r['from']}|{r['do']}|{r['info']}|{prev}"
            if hashlib.sha256(data.encode()).hexdigest() != r['hash']:
                return False
            prev = r['hash']
        return True

