# 🧬 2. ЭКОЛОГИЯ И НАНОТЕХНОЛОГИИ (NANOBOTS)
# ============================================================

class EcologySystem:
    def __init__(self):
        self.water_purity = 95.0
        self.pollution = 5.0
        self.nanobots_active = False
        self.nanobot_swarm_count = 0
        self.nanobot_efficiency = 0.8 

    def auto_cycle(self, state: SystemState):
        # Естественное загрязнение среды
        self.pollution += random.uniform(0.2, 0.7)
        
        # Работа нанороботов
        if self.nanobots_active and self.nanobot_swarm_count > 0:
            cleaning_power = (self.nanobot_swarm_count / 2000) * self.nanobot_efficiency
            self.pollution = max(0.0, self.pollution - cleaning_power)
            
            # Наноботы повышают токсичность при работе
            state.nano_toxicity += cleaning_power * 0.1
            
            # Саморазрушение наноботов
            self.nanobot_swarm_count -= random.randint(50, 150)
            if self.nanobot_swarm_count <= 0:
                self.nanobot_swarm_count = 0
                self.nanobots_active = False
        else:
            # Постепенное снижение токсичности, если боты не работают
            state.nano_toxicity = max(0.0, state.nano_toxicity - 0.5)

        self.water_purity = max(0.0, min(100.0, 100.0 - self.pollution))

    def deploy_nanobots(self, count: int):
        self.nanobot_swarm_count += count
        self.nanobots_active = True

