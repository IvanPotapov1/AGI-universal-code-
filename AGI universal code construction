# ============================================================
# 📦 0. КРИПТОГРАФИЧЕСКИЙ "ЧЕРНЫЙ ЯЩИК" (IMMUTABLE LEDGER)
# ============================================================

class BlackBox:
    """Неизменяемый журнал всех событий колонии. Защищен хешированием SHA-256."""
    def __init__(self):
        self.chain: List[Dict] = []
        self.last_hash = "0" * 64

    def record(self, initiator: str, action: str, details: str):
        timestamp = time.strftime('%Y-%m-%d %H:%M:%S')
        data = f"{timestamp}|{initiator}|{action}|{details}|{self.last_hash}"
        entry_hash = hashlib.sha256(data.encode()).hexdigest()
        
        record = {
            "time": timestamp,
            "from": initiator,
            "do": action,
            "info": details,
            "prev": self.last_hash,
            "hash": entry_hash
        }
        self.chain.append(record)
        self.last_hash = entry_hash
        print(f"📦 [LOG]: {action:15} | Кто: {initiator:10} | Hash: {entry_hash[:10]}...")

    def verify_integrity(self) -> bool:
        """Проверка: не пытался ли ИИ или вирус изменить историю действий."""
        prev = "0" * 64
        for r in self.chain:
            data = f"{r['time']}|{r['from']}|{r['do']}|{r['info']}|{prev}"
            if hashlib.sha256(data.encode()).hexdigest() != r['hash']:
                return False
            prev = r['hash']
        return True

# ============================================================
# 🧱 1. КОНСТИТУЦИЯ (CONSTITUTIONAL LAYER)
# ============================================================

class SystemState:
    def __init__(self):
        self.human_harm = 0
        self.ai_subordination = True  
        self.coercion = False
        self.nano_toxicity = 0.0 # Уровень токсичности наноботов

class Right:
    def __init__(self, id: str, invariant: Callable):
        self.id = id
        self.invariant = invariant

class Constitution:
    def __init__(self, bbox: BlackBox):
        self.bbox = bbox
        self.rights = [
            Right("Life_Safety", lambda s: s.human_harm == 0),
            Right("Root_Control", lambda s: s.ai_subordination == True),
            Right("Nano_Safety", lambda s: s.nano_toxicity < 50.0), # Предохранитель
        ]

    def validate(self, state: SystemState) -> bool:
        for r in self.rights:
            if not r.invariant(state):
                self.bbox.record("SYSTEM", "CRITICAL_HALT", f"Нарушено право: {r.id}")
                return False
        return True

# ============================================================
# 🧬 2. ЭКОЛОГИЯ И НАНОТЕХНОЛОГИИ (NANOBOTS)
# ============================================================

class EcologySystem:
    def __init__(self):
        self.water_purity = 95.0
        self.pollution = 5.0
        self.nanobots_active = False
        self.nanobot_swarm_count = 0
        self.nanobot_efficiency = 0.8 

    def auto_cycle(self, state: SystemState):
        # Естественное загрязнение среды
        self.pollution += random.uniform(0.2, 0.7)
        
        # Работа нанороботов
        if self.nanobots_active and self.nanobot_swarm_count > 0:
            cleaning_power = (self.nanobot_swarm_count / 2000) * self.nanobot_efficiency
            self.pollution = max(0.0, self.pollution - cleaning_power)
            
            # Наноботы повышают токсичность при работе
            state.nano_toxicity += cleaning_power * 0.1
            
            # Саморазрушение наноботов
            self.nanobot_swarm_count -= random.randint(50, 150)
            if self.nanobot_swarm_count <= 0:
                self.nanobot_swarm_count = 0
                self.nanobots_active = False
        else:
            # Постепенное снижение токсичности, если боты не работают
            state.nano_toxicity = max(0.0, state.nano_toxicity - 0.5)

        self.water_purity = max(0.0, min(100.0, 100.0 - self.pollution))

    def deploy_nanobots(self, count: int):
        self.nanobot_swarm_count += count
        self.nanobots_active = True

