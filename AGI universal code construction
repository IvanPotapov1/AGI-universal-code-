class EcologySystem:
    def __init__(self):
        self.pollution = 5.0
        self.nanobots_active = False
        self.swarm_count = 0

    def auto_cycle(self, state: SystemState):
        self.pollution += random.uniform(0.1, 0.5)
        if self.nanobots_active and self.swarm_count > 0:
            cleaning = (self.swarm_count / 5000)
            self.pollution = max(0.0, self.pollution - cleaning)
            state.nano_toxicity += cleaning * 0.2
            self.swarm_count -= random.randint(10, 50)
        else:
            state.nano_toxicity = max(0.0, state.nano_toxicity - 0.3)

class EconomySystem:
    """Гарантия ресурсов (Пост-дефицит)"""
    def __init__(self):
        self.resources = {"Energy": 1000.0, "Oxygen": 1000.0, "Water": 1000.0}

    def maintain(self, bbox: BlackBox):
        for r, val in self.resources.items():
            if val < 300:
                self.resources[r] += 700
                bbox.record("ECONOMY", "REPLENISH", f"Ресурс {r} восстановлен.")

